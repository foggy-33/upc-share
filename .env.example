# MySQL
MYSQL_DATABASE=download_site
MYSQL_USER=download_site
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
MYSQL_PORT=3306
MYSQL_BUFFER_POOL_SIZE=512M
MYSQL_MAX_CONNECTIONS=500

# App
JWT_SECRET=replace-with-content-of-dot-secret-key
NODE_NAME=public
COOKIE_SECURE=true
DB_POOL_MAX=40
DB_POOL_MIN_IDLE=10
TOMCAT_MAX_THREADS=300
TOMCAT_MAX_CONNECTIONS=10000
TOMCAT_ACCEPT_COUNT=500
SCAN_RESOURCES_ON_STARTUP=true
MIGRATE_SQLITE=false

# Vue build-time route config
VITE_CAMPUS_ORIGIN=https://in.upcshare.cn
VITE_PUBLIC_ORIGINS=https://upcshare.cn,https://www.upcshare.cn
VITE_ACCESS_ROUTE_PROBE_PATH=/api/ping
VITE_ACCESS_ROUTE_TIMEOUT_MS=1200
