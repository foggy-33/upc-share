[Unit]
Description=Download Site (FastAPI + Uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/download-site
Environment="PATH=/opt/download-site/venv/bin"
ExecStart=/opt/download-site/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

# 内存限制，防止 OOM
MemoryMax=1G

[Install]
WantedBy=multi-user.target
